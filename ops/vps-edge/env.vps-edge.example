SAFE_ROAD_ENV=production
SAFE_ROAD_DEPLOYMENT_TIER=shared-vps
SAFE_ROAD_PUBLIC_HOST=safe.quorix.io.vn
SAFE_ROAD_CADDY_EMAIL=admin@quorix.io.vn

# Generate and store these outside Git.
SAFE_ROAD_ADMIN_PASSWORD=replace-with-long-password
SAFE_ROAD_ADMIN_API_KEY=replace-with-64-char-random-hex

# First deploy baseline: no cloud AI and no public DoT until HTTPS is healthy.
SAFE_ROAD_AI_PROVIDER=none
SAFE_ROAD_DNS_DOT_ENABLED=false

SAFE_ROAD_REDIS_ADDR=redis:6379
SAFE_ROAD_REDIS_MAXMEMORY=256mb

# Set this to the VPS public IPv4 before enabling sinkhole blocking.
SAFE_ROAD_BLOCK_PAGE_IP=replace-with-vps-public-ip
SAFE_ROAD_BLOCK_PAGE_SUPPORT_EMAIL=contact@quorix.io.vn
SAFE_ROAD_DNS_BLOCK_STRATEGY=sinkhole

SAFE_ROAD_AGENT_ENABLED=false
SAFE_ROAD_AGENT_FEED_PRESET=
SAFE_ROAD_AGENT_FEED_SOURCES=

SAFE_ROAD_DOCKER_LOG_MAX_SIZE=10m
SAFE_ROAD_DOCKER_LOG_MAX_FILE=5
