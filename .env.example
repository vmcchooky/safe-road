SAFE_ROAD_ENV=local
SAFE_ROAD_DEPLOYMENT_TIER=budget-vps

# --- Production Edge (Caddy + DuckDNS) ---
SAFE_ROAD_PUBLIC_HOST=saferoad.example.com
SAFE_ROAD_CADDY_EMAIL=admin@example.com
SAFE_ROAD_DUCKDNS_DOMAIN=
SAFE_ROAD_DUCKDNS_TOKEN=

SAFE_ROAD_HEALTHCHECK_PORT=8080
SAFE_ROAD_HEALTHCHECK_PATH=/healthz

SAFE_ROAD_CORE_API_ADDR=:8080
SAFE_ROAD_DNS_RESOLVER_ADDR=:8081
SAFE_ROAD_SHUTDOWN_TIMEOUT_MS=10000

SAFE_ROAD_REDIS_ADDR=redis:6379
SAFE_ROAD_REDIS_PASSWORD=
SAFE_ROAD_REDIS_DB=0
SAFE_ROAD_REDIS_TIMEOUT_MS=250
SAFE_ROAD_REDIS_MAXMEMORY=256mb

SAFE_ROAD_THREAT_FEED_KEY=safe-road:threat:feed
SAFE_ROAD_THREAT_FEED_SOURCE=
SAFE_ROAD_FEED_SYNC_TIMEOUT_MS=30000
SAFE_ROAD_FEED_SYNC_INTERVAL_SECONDS=86400
# --- AI Provider Configuration ---
# Options: none (disabled), gemini (free cloud), ollama (local offline), hybrid (ollama with gemini fallback)
# Note: "gemini" is perfect for low-RAM VPS (< 2GB RAM), while "ollama" is ideal for full offline privacy.
SAFE_ROAD_AI_PROVIDER=gemini

# Google Gemini API Settings (Cloud AI)
SAFE_ROAD_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
SAFE_ROAD_GEMINI_API_KEY=
SAFE_ROAD_GEMINI_MODEL=gemini-2.5-flash-lite
SAFE_ROAD_GEMINI_TIMEOUT_MS=3000

# Local Ollama Settings (Offline AI)
SAFE_ROAD_OLLAMA_BASE_URL=http://localhost:11434
SAFE_ROAD_OLLAMA_MODEL=gemma2:2b
SAFE_ROAD_OLLAMA_TIMEOUT_MS=5000

SAFE_ROAD_CACHE_TTL_ALLOWED_SECONDS=10800
SAFE_ROAD_CACHE_TTL_SUSPICIOUS_SECONDS=3600
SAFE_ROAD_CACHE_TTL_BLOCKED_SECONDS=21600

SAFE_ROAD_UPSTREAM_DOH_URL=https://cloudflare-dns.com/dns-query
SAFE_ROAD_UPSTREAM_DOH_TIMEOUT_MS=3000
SAFE_ROAD_BLOCK_PAGE_IP=127.0.0.1
SAFE_ROAD_DNS_BLOCK_TTL_SECONDS=60

SAFE_ROAD_DASHBOARD_RECENT_LIMIT=25

# --- SQLite (Telemetry & Local Overrides) ---
SAFE_ROAD_SQLITE_PATH=./data/safe-road.db
SAFE_ROAD_TELEMETRY_RETENTION_DAYS=30

# --- Rate Limiting ---
SAFE_ROAD_RATELIMIT_ENABLED=true
SAFE_ROAD_RATELIMIT_ANALYZE_RPM=10
SAFE_ROAD_RATELIMIT_ANALYZE_BURST=5
SAFE_ROAD_RATELIMIT_OVERRIDE_RPM=20
SAFE_ROAD_RATELIMIT_OVERRIDE_BURST=5
SAFE_ROAD_RATELIMIT_TELEMETRY_RPM=30
SAFE_ROAD_RATELIMIT_TELEMETRY_BURST=10
SAFE_ROAD_RATELIMIT_DOH_RPM=100
SAFE_ROAD_RATELIMIT_DOH_BURST=20
SAFE_ROAD_RATELIMIT_DEFAULT_RPM=60
SAFE_ROAD_RATELIMIT_DEFAULT_BURST=15

# --- AI Agent Workflow ---
SAFE_ROAD_AGENT_ENABLED=false
SAFE_ROAD_AGENT_AUDIT_INTERVAL_SECONDS=3600
SAFE_ROAD_AGENT_AUDIT_TIMEOUT_SECONDS=300
SAFE_ROAD_AGENT_AUDIT_MIN_OCCURRENCES=3
SAFE_ROAD_AGENT_AUDIT_MAX_PER_CYCLE=50
SAFE_ROAD_AGENT_AUDIT_CONFIDENCE_THRESHOLD=0.7
SAFE_ROAD_AGENT_ENRICH_TIMEOUT_SECONDS=5
SAFE_ROAD_AGENT_FEED_SOURCES=
# Preset free feeds. Enable by copying this value into SAFE_ROAD_AGENT_FEED_SOURCES.
# https://urlhaus.abuse.ch/downloads/csv_recent/,https://rescure.me/rescure_domain_blacklist.txt
SAFE_ROAD_AGENT_FEED_INTERVAL_SECONDS=86400
SAFE_ROAD_AGENT_FEED_TIMEOUT_SECONDS=120
SAFE_ROAD_AGENT_WEBHOOK_URL=
SAFE_ROAD_AGENT_ALERT_INTERVAL_SECONDS=900
SAFE_ROAD_AGENT_ALERT_TIMEOUT_SECONDS=30
SAFE_ROAD_AGENT_ALERT_MIN_EVENTS=1

# --- Whitelist Auto-Update ---
SAFE_ROAD_AGENT_WHITELIST_ENABLED=true
SAFE_ROAD_AGENT_WHITELIST_INTERVAL_SECONDS=604800
SAFE_ROAD_AGENT_WHITELIST_TIMEOUT_SECONDS=600
SAFE_ROAD_AGENT_WHITELIST_SOURCE_URL=https://tranco-list.eu/download/L/1000000

# --- DNS-over-TLS (DoT) Configurations ---
SAFE_ROAD_DNS_DOT_ENABLED=true
SAFE_ROAD_DNS_DOT_CONTAINER_PORT=8533
SAFE_ROAD_DNS_DOT_PUBLISHED_PORT=853
SAFE_ROAD_DNS_DOT_CERT_FILE=
SAFE_ROAD_DNS_DOT_KEY_FILE=
SAFE_ROAD_RATELIMIT_DOT_RPM=100
SAFE_ROAD_RATELIMIT_DOT_BURST=20

# --- Advanced Alert Settings ---
# Telegram Configuration
SAFE_ROAD_ALERT_TELEGRAM_ENABLED=false
SAFE_ROAD_ALERT_TELEGRAM_TOKEN=your_bot_token_here
SAFE_ROAD_ALERT_TELEGRAM_CHAT_ID=your_chat_id_here

# Slack Configuration
SAFE_ROAD_ALERT_SLACK_ENABLED=false
SAFE_ROAD_ALERT_SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Email Configuration
SAFE_ROAD_ALERT_EMAIL_ENABLED=false
SAFE_ROAD_ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
SAFE_ROAD_ALERT_EMAIL_SMTP_PORT=587
SAFE_ROAD_ALERT_EMAIL_FROM=sender@gmail.com
SAFE_ROAD_ALERT_EMAIL_PASSWORD=your_app_password
SAFE_ROAD_ALERT_EMAIL_TO=admin@example.com
